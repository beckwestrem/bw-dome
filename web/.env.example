# --- Local: copy to web/.env.local  |  Production: set on Railway → web service → Variables ---
#
# Railway does not read this file from the repo. After adding variables in the dashboard,
# redeploy (or restart) the service so email and DB settings take effect.

# Optional Postgres storage. Leave empty for local JSON storage in web/data/app-data.json.
DATABASE_URL=

# Personal password auth. If unset, auth is disabled for local dev.
APP_PASSWORD=

# Optional: Bearer secret for POST /api/ingest/mcp (MCP / automation).
# If unset while APP_PASSWORD is set, that route accepts a logged-in session cookie.
MCP_INGEST_SECRET=
# When MCP_INGEST_SECRET is set, automation writes to this data scope (default system_mcp). Optional.
MCP_INGEST_OWNER_ID=

# Email digest — required on Railway (web service Variables) for any real email:
CRON_SECRET=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
# Aliases also accepted: SMTP_USER, SMTP_PASS, SMTP_FROM / MAIL_FROM / EMAIL_FROM for sender
SMTP_PASSWORD=
DIGEST_SENDER_EMAIL=
#
# Cron: POST https://<your-railway-domain>/api/cron/digest  Header: Authorization: Bearer <CRON_SECRET>
# Instant test (logged in): Settings → "Send test digest now" → POST /api/digest/send-now

# LLM for digest email ~5 bullets (optional). Anthropic is tried first if set, then OpenAI.
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-haiku-20241022
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
#
# Stakeholder daily email: calendar for "Completed today" (row updatedAt vs completed status). Default America/Chicago.
# SUMMARY_TIMEZONE=America/New_York
